# Copy to .env and fill values. Never commit .env.

# PostgreSQL (Prisma / hosted DB URL format)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# SwipePoint merchant secret (Bearer token for https://swipepointe.com/api/charge)
SWIPEPOINT_API_SECRET=sk_your_secret_here

# payment provider mode: internal | swipepoint
PAYMENT_PROVIDER_MODE=internal

# Optional override
SWIPEPOINT_CHARGE_URL=https://swipepointe.com/api/charge

# Django
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
